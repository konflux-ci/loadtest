{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>konflux-ci/mintmaker-presets:cve-automerge-all"],
  "packageRules": [
    {
      "description": "Automerge all MintMaker updates after CI passes",
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "automerge": true
    }
  ],
  "gomod": {
    "packageRules": [
      {
        "matchDepTypes": ["indirect"],
        "enabled": false
      }
    ]
  }
}
